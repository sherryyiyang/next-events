[
  {
    "id": "TC001",
    "title": "Successful login redirects to Profile with success toast",
    "description": "Verifies a user can log in with valid credentials, sees a success toast, and is redirected to the profile page.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Log In\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"success\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/profile\""
      }
    ]
  },
